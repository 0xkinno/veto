{
  "name": "@veto/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/gateway.ts",
    "build": "esbuild src/index.ts src/gateway.ts --bundle --platform=node --target=node20 --format=esm --outdir=dist --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/gateway.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke": "node smoke.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@okxweb3/x402-core": "^0.1.0",
    "@okxweb3/x402-evm": "^0.2.1",
    "@okxweb3/x402-express": "^0.1.1",
    "dotenv": "^17.4.2",
    "ethers": "^6.13.2",
    "express": "^5.2.1",
    "fastify": "^4.28.1",
    "http-proxy-middleware": "^3.0.7",
    "ioredis": "^5.4.1",
    "viem": "^2.55.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.16.5",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
