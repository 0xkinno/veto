# ============================================================
# VETO ENGINE — three independent chains, set each deliberately
# ============================================================
PORT=8787

# ---- 1. SIMULATION CHAIN ------------------------------------
# The chain VETO verifies transactions on. MUST be the chain the
# calling agent actually transacts on. OKX.AI agents are on
# X Layer MAINNET, so this should be mainnet in production.
#   mainnet: https://rpc.xlayer.tech        (chain 196)
#   testnet: https://testrpc.xlayer.tech    (chain 1952)
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_CHAIN_ID=196

# ---- 2. ATTESTATION CHAIN -----------------------------------
# Where your VetoAttestation contract lives. Can differ from the
# simulation chain. If blank, falls back to XLAYER_RPC_URL.
# Your contract is on TESTNET, so point this at testnet.
ATTESTATION_RPC_URL=https://testrpc.xlayer.tech
ATTESTATION_ADDRESS=0xDC7cE940E10ef664B78D185d81AC382AA218f7c4
ATTESTER_PRIVATE_KEY=

# ---- 3. PAYMENT (x402) --------------------------------------
# From the OKX dev portal, obtained during ASP registration.
# Payment ENFORCES only when all four below are set. Until then
# the engine runs OPEN (dev mode) and serves for free.
# USDT settles on X Layer MAINNET (196) to VETO_PAYTO_ADDRESS.
OKX_API_BASE=https://web3.okx.com
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
VETO_PAYTO_ADDRESS=

# ---- optional -----------------------------------------------
# Live drainer feed (JSON array of addresses) + inline extras.
DRAINER_FEED_URL=
DRAINER_ADDRESSES=
REGISTERED_RECIPIENTS=
REDIS_URL=
